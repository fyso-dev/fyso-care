---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto" activePage="contacto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-warm-900">Contacto</h1>
      <p class="mt-2 text-warm-500">Estamos para ayudarte</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">
      <!-- Info -->
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-warm-100">
          <h2 class="text-lg font-bold text-warm-900 mb-4">Informacion</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <div>
                <p class="font-medium text-warm-900">Direccion</p>
                <p class="text-sm text-warm-500" data-sc="address">Av. Corrientes 1234, CABA, Buenos Aires</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              <div>
                <p class="font-medium text-warm-900">Telefono</p>
                <p class="text-sm text-warm-500" data-sc="phone">(011) 1234-5678</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              <div>
                <p class="font-medium text-warm-900">Email</p>
                <p class="text-sm text-warm-500" data-sc="email">info@consultorio.com</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-sm border border-warm-100">
          <h2 class="text-lg font-bold text-warm-900 mb-4">Horarios de atencion</h2>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-warm-600">Lunes a Viernes</span>
              <span class="font-medium text-warm-900" data-sc="hours_weekday">8:00 - 20:00</span>
            </div>
            <div class="flex justify-between">
              <span class="text-warm-600">Sabados</span>
              <span class="font-medium text-warm-900" data-sc="hours_saturday">9:00 - 14:00</span>
            </div>
            <div class="flex justify-between">
              <span class="text-warm-600">Domingos</span>
              <span class="font-medium text-warm-900" data-sc="hours_sunday">Cerrado</span>
            </div>
            <div class="flex justify-between pt-2 border-t border-warm-100">
              <span class="text-red-600 font-medium">Emergencias</span>
              <span class="font-medium text-red-600" data-sc="emergency_hours">24 horas</span>
            </div>
          </div>
        </div>

        <a
          href="https://wa.me/5491112345678?text=Hola!%20Quiero%20consultar%20sobre%20la%20veterinaria"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-[#25d366] text-white font-semibold hover:bg-[#1ebe57] transition-colors"
          data-sc-wa
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escribinos por WhatsApp
        </a>
      </div>

      <!-- Map -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-warm-100 h-96 lg:h-auto">
        <iframe
          id="sc-google-maps"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.0168878895383!2d-58.38375908477032!3d-34.60373888045951!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bccacb00000001%3A0x40!2sAv.%20Corrientes%2C%20Buenos%20Aires!5e0!3m2!1ses!2sar!4v1600000000000!5m2!1ses!2sar"
          width="100%"
          height="100%"
          style="border:0; min-height: 384px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>

  <script is:inline>
    // Update Google Maps iframe when config loads
    var checkMap = setInterval(function() {
      try {
        var tenantId = import.meta.env.PUBLIC_TENANT_ID || 'consultorio';
        var cached = sessionStorage.getItem(tenantId + '_site_config');
        if (!cached) return;
        var parsed = JSON.parse(cached);
        var d = parsed.data;
        if (d && d.google_maps_url) {
          var iframe = document.getElementById('sc-google-maps');
          if (iframe && iframe.src !== d.google_maps_url) {
            iframe.src = d.google_maps_url;
          }
        }
        clearInterval(checkMap);
      } catch(e) { clearInterval(checkMap); }
    }, 200);
    setTimeout(function() { clearInterval(checkMap); }, 5000);
  </script>
</Layout>
