# Fyso tenant identifier (used in X-Tenant-ID API header)
# Server-side only (SSR/build-time):
TENANT_ID=consultorio
# Client-side accessible (Astro PUBLIC_ prefix required):
PUBLIC_TENANT_ID=consultorio

# Fyso developer token for SSR (generate via Fyso dashboard or MCP)
FYSO_API_TOKEN=your-developer-token-here
